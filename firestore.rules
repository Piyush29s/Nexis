rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────
    // Only the owner can read/write their own document.
    // Email must never be stored — blocked by the rule.
    // Allowed fields: username (string), createdAt (timestamp).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !('email' in request.resource.data)
                    && request.resource.data.username is string;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !('email' in request.resource.data);

      allow delete: if false;
    }

    // ── Usernames ─────────────────────────────────────────────────
    // Any authenticated user can read (needed for uniqueness check).
    // Create allowed if the userId field matches the requester.
    match /usernames/{username} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    // ── Rooms ─────────────────────────────────────────────────────
    // Read only by participants; write always false (Admin SDK only).
    match /rooms/{roomId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow write: if false;

      // Messages: read only by room participants. Write always false.
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;
        allow write, delete: if false;
      }
    }
  }
}
